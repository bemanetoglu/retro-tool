  {
    "id": "TC001",
    "title": "Join room from home page with a valid 6-digit code",
    "description": "Verifies that entering a valid 6-digit room code and clicking Join navigates the user to the join page for that code.",
    "category": "Home Page Navigation",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Room Code\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"123456\" into the room code input field"
      },
      {
        "type": "action",
        "description": "Click the join button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/join/123456\""
